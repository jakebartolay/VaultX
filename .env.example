# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CURRENCY=PHP

# Production auth/backend iteration
JWT_SECRET=replace-with-a-strong-32-byte-secret
BCRYPT_SALT_ROUNDS=12

# Local login system
AUTH_USER_ID=local-user
AUTH_NAME=VaultX User
AUTH_EMAIL=admin@vaultx.local
AUTH_PASSWORD=vaultx123

# Supabase/PostgreSQL option
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# XAMPP MySQL option
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=vaultx
MYSQL_USER=root
MYSQL_PASSWORD=

# Cloud storage option for receipts, asset photos, and documents
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=finance-files
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Security/rate limiting option for API deployment
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
